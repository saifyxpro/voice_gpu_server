# Server
VOICE_GPU_HOST=0.0.0.0
VOICE_GPU_PORT=8765
VOICE_GPU_API_KEY=change-me-to-a-long-random-string

# Public URL (set after running scripts/start-ngrok.sh)
# Pipecat bot reads VOICE_GPU_BASE_URL — use the ngrok https URL here.
VOICE_GPU_BASE_URL=https://your-subdomain.ngrok-free.app

# Model devices (cuda, cuda:0, cpu)
TTS_DEVICE=cuda
STT_DEVICE=cuda

# Load models at startup (true) or on first request (false)
EAGER_LOAD_MODELS=false

# Chatterbox Turbo (TTS)
TTS_MODEL=ResembleAI/chatterbox-turbo
# Voice id matches filename without extension, e.g. voices/kelvin.wav → kelvin
DEFAULT_VOICE_ID=kelvin
VOICES_DIR=./voices

# Canary Qwen (STT) — requires NeMo optional extra
STT_MODEL=nvidia/canary-qwen-2.5b
STT_SAMPLE_RATE=16000

# ngrok (for exposing H100 server to Pipecat client)
NGROK_AUTHTOKEN=your-ngrok-authtoken

# Pipecat bot (OpenRouter LLM stays in cloud — not on GPU)
OPENROUTER_API_KEY=your-openrouter-key
