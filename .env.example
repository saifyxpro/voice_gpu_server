# Server
VOICE_GPU_HOST=0.0.0.0
VOICE_GPU_PORT=8765
VOICE_GPU_API_KEY=change-me-to-a-long-random-string

# Public URL (set after running scripts/start-ngrok.sh)
# Pipecat bot reads VOICE_GPU_BASE_URL — use the ngrok https URL here.
VOICE_GPU_BASE_URL=https://your-subdomain.ngrok-free.app

# Model devices (cuda, cuda:0, cpu)
TTS_DEVICE=cuda
STT_DEVICE=cuda

# Load models at startup (true) — downloads weights before first request
EAGER_LOAD_MODELS=true

# Chatterbox Turbo (TTS)
TTS_MODEL=ResembleAI/chatterbox-turbo
# Voice id matches filename without extension, e.g. voices/kelvin.wav → kelvin
DEFAULT_VOICE_ID=kelvin
VOICES_DIR=./voices

# TTS generation tuning (Turbo ignores cfg_weight at generate time; exaggeration applies at voice prep)
TTS_TEMPERATURE=0.8
TTS_TOP_P=0.95
TTS_TOP_K=1000
TTS_REPETITION_PENALTY=1.2
TTS_EXAGGERATION=0.5
TTS_NORM_LOUDNESS=true
# Streaming: lower chunk tokens = faster first audio byte (~16 tokens ≈ 0.6s of speech)
TTS_STREAM_CHUNK_TOKENS=16
TTS_STREAM_CROSSFADE_MS=12.0
TTS_MAX_GEN_LEN=1000
TTS_N_CFM_TIMESTEPS=2

# Canary Qwen (STT) — requires NeMo optional extra
STT_MODEL=nvidia/canary-qwen-2.5b
STT_SAMPLE_RATE=16000

# ngrok — expose this server to Pipecat / remote clients
# One-time auth on the H100 (if not already done):
#   ngrok config add-authtoken YOUR_TOKEN
# Static free dev domain: Dashboard → Gateway → Domains
NGROK_URL=https://your-name.ngrok-free.dev
# Optional — only if you prefer storing token in .env instead of ngrok config
# NGROK_AUTHTOKEN=your-ngrok-authtoken
